SECRET_KEY=your-very-secret-key-here-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — leave blank for SQLite (local dev), PostgreSQL for production
DATABASE_URL=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# EMAIL — Gmail SMTP
#
# Development: leave EMAIL_USER blank → emails print to terminal (console backend)
# Production : fill in EMAIL_USER and EMAIL_PASS to send real emails via Gmail
#
# How to get a Gmail App Password:
#   1. Enable 2-Step Verification on your Google account
#      https://myaccount.google.com/security
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Select app: Mail → Generate
#   4. Copy the 16-character password into EMAIL_PASS below
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

EMAIL_USER=yourapp@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx
DEFAULT_FROM_EMAIL=Campus Lost & Found <yourapp@gmail.com>

# AWS S3 (optional — for production media storage)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
